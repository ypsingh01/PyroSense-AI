# PyroSense AI environment configuration
# Copy to .env and edit values as needed.

# -----------------------------
# Model
# -----------------------------
YOLO_MODEL_PATH=models/weights/best.pt
CONF_THRESHOLD=0.5
IOU_THRESHOLD=0.45
DEVICE=auto   # auto, cpu, cuda, mps

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=sqlite:///./pyrosense.db
# DATABASE_URL=postgresql://user:pass@localhost/pyrosense

# -----------------------------
# LLM (choose one)
# -----------------------------
LLM_PROVIDER=groq   # groq or ollama
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------
# Alerts
# -----------------------------
ALERT_COOLDOWN_SECONDS=60

EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=alert@email.com

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/fire-alert

# -----------------------------
# MLflow
# -----------------------------
MLFLOW_TRACKING_URI=./mlruns

